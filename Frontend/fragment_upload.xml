<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_upload.xml
    Screen 1: MRI Scan Upload
    Matches the "Upload Sc..." screen from the Stitch design.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    >

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/margin_mobile"
            android:paddingEnd="@dimen/margin_mobile"
            android:paddingTop="@dimen/spacing_md">

            <!-- ─── Header ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_logo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_brain_logo"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.NeuroAge.Circle"
                    android:background="@color/surface_container_high"
                    android:padding="4dp"
                    android:layout_marginEnd="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NEUROAGE"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:textSize="@dimen/text_label_caps"
                    android:letterSpacing="0.1"
                    android:textColor="@color/on_surface"
                    android:textAllCaps="true" />

                <!-- 3-dot overflow menu button -->
                <ImageView
                    android:id="@+id/btn_overflow_menu"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_menu"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/on_surface"
                    android:contentDescription="More options" />

            </LinearLayout>
            <!-- ─── AI Status Badge ─── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_ai_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginBottom="@dimen/spacing_xs">

                <!-- Pulsing dot -->
                <View
                    android:id="@+id/dot_ai_status"
                    android:layout_width="@dimen/dot_indicator_size"
                    android:layout_height="@dimen/dot_indicator_size"
                    android:background="@drawable/bg_dot_pulse_blue"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI ENGINE ACTIVE"
                    android:fontFamily="@font/jetbrains_mono_medium"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:textColor="@color/primary"
                    android:textAllCaps="true" />

            </LinearLayout>

            <!-- ─── Page Title ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MRI Scan Upload"
                android:fontFamily="@font/inter_semibold"
                android:textSize="@dimen/text_headline_lg_mobile"
                android:textColor="@color/on_surface"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neural network ready for volumetric analysis."
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/text_body_sm"
                android:textColor="@color/on_surface_variant"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- ─── Drop Zone / Upload Area ─── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_drop_zone"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true">

                <!-- Scan line animation overlay -->
                <View
                    android:id="@+id/view_scan_line"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@drawable/gradient_scan_line"
                    android:layout_gravity="top" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/spacing_md">

                    <!-- Icon Container -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardBackgroundColor="@color/surface_container_high"
                        app:strokeColor="@color/primary_20"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_neurology"
                            app:tint="@color/primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_upload_title"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Brain MRI"
                        android:fontFamily="@font/inter_semibold"
                        android:textSize="@dimen/text_title_md"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="6dp" />


                    <!-- Format Badge -->
                    <TextView
                        android:id="@+id/tv_upload_filetype"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NIfTI"
                        android:fontFamily="@font/jetbrains_mono_medium"
                        android:textSize="10sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/on_surface_variant"
                        android:background="@drawable/bg_format_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                    <TextView
                        android:id="@+id/tv_selected_file"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No file selected"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/jetbrains_mono_medium"
                        android:textSize="12sp"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Age Input Section ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHRONOLOGICAL AGE"
                android:fontFamily="@font/jetbrains_mono_medium"
                android:textSize="@dimen/text_label_caps"
                android:letterSpacing="0.05"
                android:textColor="@color/on_surface_variant"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <!-- Input + Unit suffix -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_patient_age"
                    style="@style/Widget.NeuroAge.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter age">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_patient_age"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:fontFamily="@font/jetbrains_mono_semibold"
                        android:textSize="@dimen/text_data_numeric"
                        android:textColor="@color/primary"
                        android:paddingEnd="56dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YEARS"
                    android:fontFamily="@font/jetbrains_mono_medium"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:textColor="@color/on_surface_variant_60"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="16dp" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Required for normative database comparison"
                android:fontFamily="@font/inter_regular"
                android:textSize="10sp"
                android:textColor="@color/on_surface_variant_40"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- ─── CTA Button ─── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_analysis"
                style="@style/Widget.NeuroAge.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="START NEURAL ANALYSIS"
                app:icon="@drawable/ic_psychiatry"
                app:iconGravity="textStart"
                app:iconTint="@color/on_primary_container"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- ─── Recent Scans Section ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT SCANS"
                    android:fontFamily="@font/jetbrains_mono_medium"
                    android:textSize="@dimen/text_label_caps"
                    android:letterSpacing="0.05"
                    android:textColor="@color/on_surface_variant"
                    android:textAllCaps="true" />

                <ImageView
                    android:id="@+id/iv_history_shortcut"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_history"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    app:tint="@color/primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_no_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No scan history available"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/layout_recent_scans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ─── Bottom Navigation ─── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        style="@style/Widget.NeuroAge.BottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:layout_behavior="@string/hide_bottom_view_on_scroll_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>