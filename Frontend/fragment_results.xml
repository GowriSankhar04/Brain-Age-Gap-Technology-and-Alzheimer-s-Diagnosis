<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_results.xml
    Screen 3: Neuroimaging Analysis Dashboard
    The most data-rich screen — matches Image 2 exactly.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    >

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/margin_mobile"
            android:paddingEnd="@dimen/margin_mobile"
            android:paddingTop="@dimen/spacing_md">

            <!-- ─── Header: Logo + Icons ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_logo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_brain_logo"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.NeuroAge.Circle"
                    android:background="@color/surface_container_high"
                    android:padding="4dp"
                    android:layout_marginEnd="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NEUROAGE"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:textSize="@dimen/text_label_caps"
                    android:letterSpacing="0.1"
                    android:textColor="@color/on_surface"
                    android:textAllCaps="true" />

                <!-- 3-dot overflow menu button -->
                <ImageView
                    android:id="@+id/btn_overflow_menu"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_menu"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/on_surface"
                    android:contentDescription="More options" />

            </LinearLayout>


            <!-- ─── Page Title ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neuroimaging Analysis Dashboard"
                android:fontFamily="@font/inter_semibold"
                android:textSize="@dimen/text_headline_lg_mobile"
                android:textColor="@color/on_surface"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="@dimen/spacing_sm" />



            <!-- ─── AI Diagnostic Card (Predicted Age) ─── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_predicted_age"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <!-- AI Active Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_ai_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_dot_pulse_blue"
                            android:layout_marginEnd="5dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI ANALYSIS ACTIVE"
                            android:fontFamily="@font/jetbrains_mono_medium"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                    <!-- Circular Progress + Age -->
                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <!-- Circular arc progress (custom view or ProgressBar styled)

                         ||||||||||||||||||||||||-|
                         -->
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progress_brain_age"
                            android:layout_width="250dp"
                            android:layout_height="250dp"
                            android:layout_gravity="center"
                            android:progress="70"
                            app:trackThickness="8dp"
                            app:indicatorColor="@color/primary_container"
                            app:trackColor="@color/surface_container_high"
                            app:trackCornerRadius="4dp"
                            app:indicatorSize="80dp"/>

                        <!-- Age Value overlay -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PREDICTED AGE"
                                android:fontFamily="@font/jetbrains_mono_medium"
                                android:textSize="9sp"
                                android:letterSpacing="0.05"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/tv_predicted_age"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="42"
                                android:layout_marginTop="20dp"
                                android:layout_marginBottom="20dp"
                                android:fontFamily="@font/inter_bold"
                                android:textSize="40sp"
                                android:textColor="@color/on_surface"
                                android:lineSpacingExtra="-4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="YEARS"
                                android:fontFamily="@font/jetbrains_mono_medium"
                                android:textSize="10sp"
                                android:letterSpacing="0.05"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                    </FrameLayout>

                    <!-- Brain age insight text -->
                    <TextView
                        android:id="@+id/tv_brain_age_insight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Brain is 3 years younger than average"
                        android:fontFamily="@font/inter_semibold"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/on_surface"
                        android:gravity="center"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant_20"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Chronological vs Predicted -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHRONOLOGICAL"
                                android:fontFamily="@font/jetbrains_mono_medium"
                                android:textSize="9sp"
                                android:letterSpacing="0.05"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/tv_chrono_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="45y"
                                android:fontFamily="@font/jetbrains_mono_semibold"
                                android:textSize="@dimen/text_data_numeric"
                                android:textColor="@color/on_surface" />

                        </LinearLayout>

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/outline_variant_20" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PREDICTED"
                                android:fontFamily="@font/jetbrains_mono_medium"
                                android:textSize="9sp"
                                android:letterSpacing="0.05"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/tv_predicted_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="42y"
                                android:fontFamily="@font/jetbrains_mono_semibold"
                                android:textSize="@dimen/text_data_numeric"
                                android:textColor="@color/primary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── AI PATTERN ANALYSIS Card (Alzheimer's) ─── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_clinical_assessment"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <!-- Icon -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardBackgroundColor="@color/surface_container_high"
                        app:cardElevation="0dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_brain_assessment"
                            app:tint="@color/on_surface_variant" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Category label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Neuroimaging Pattern Analysis"
                        android:fontFamily="@font/jetbrains_mono_medium"
                        android:textSize="@dimen/text_label_caps"
                        android:letterSpacing="0.05"
                        android:textColor="@color/on_surface_variant"
                        android:textAllCaps="true"
                        android:gravity="center"
                        android:layout_marginBottom="2dp"
                        android:paddingBottom="10dp"/>


                    <!-- NORMAL Status Box -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_diagnosis_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardBackgroundColor="@color/surface_container_high"
                        app:strokeColor="@color/primary_container"
                        app:strokeWidth="1dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/primary_container"
                                android:layout_marginEnd="@dimen/spacing_xs" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_diagnosis_result"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="NORMAL"
                                    android:fontFamily="@font/jetbrains_mono_semibold"
                                    android:textSize="22sp"
                                    android:textColor="@color/primary_container"
                                    android:letterSpacing="0.02" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="STABLE COGNITIVE INDICATOR"
                                    android:fontFamily="@font/jetbrains_mono_medium"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.05"
                                    android:textColor="@color/primary" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- AI analysis description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI analysis identified low similarity to reference neurodegenerative imaging patterns. in targeted cortical regions."
                        android:fontFamily="@font/inter_regular"
                        android:textStyle="italic"
                        android:textSize="@dimen/text_body_sm"
                        android:textColor="@color/on_surface_variant"
                        android:gravity="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Brain Scan Image Section ─── -->

            <!-- ─── Critical Biomarkers Card ─── -->
            <!-- ───────────────────────────────────────────── -->
            <!-- Critical Biomarkers Card -->
            <!-- ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_biomarkers"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm">


            </com.google.android.material.card.MaterialCardView>


            <!-- ───────────────────────────────────────────── -->
            <!-- Neuro Efficiency -->
            <!-- ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_neuro_efficiency"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm">


            </com.google.android.material.card.MaterialCardView>


            <!-- ───────────────────────────────────────────── -->
            <!-- Stress Index -->
            <!-- ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stress_index"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">


            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ─── Bottom Navigation ─── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        style="@style/Widget.NeuroAge.BottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        />
    <!--app:selectedItemId="@id/nav_results"-->
</androidx.coordinatorlayout.widget.CoordinatorLayout>