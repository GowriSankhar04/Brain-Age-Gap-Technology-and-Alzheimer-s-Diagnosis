<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_analyzing.xml
    Screen 2: Analyzing Neural Structures
    Shows animated brain scan processing progress.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    >

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/margin_mobile"
            android:paddingEnd="@dimen/margin_mobile"
            android:paddingTop="@dimen/spacing_md">

            <!-- ─── Header ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_brain_logo"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.NeuroAge.Circle"
                    android:background="@color/surface_container_high"
                    android:padding="4dp"
                    android:layout_marginEnd="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEUROAGE"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:textSize="@dimen/text_label_caps"
                    android:letterSpacing="0.1"
                    android:textColor="@color/on_surface"
                    android:textAllCaps="true" />

            </LinearLayout>

            <!-- ─── Brain Scan Visualization Card ─── -->

            <!-- ─── Status Card ─── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <!-- Analyzing Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analyzing Neural Structures…"
                        android:fontFamily="@font/inter_semibold"
                        android:textSize="@dimen/text_title_md"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="4dp" />

                    <!-- Protocol Label -->

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant_20"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Completion row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="COMPLETION"
                            android:fontFamily="@font/jetbrains_mono_medium"
                            android:textSize="@dimen/text_label_caps"
                            android:letterSpacing="0.05"
                            android:textColor="@color/on_surface_variant"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tv_completion_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="44%"
                            android:fontFamily="@font/jetbrains_mono_semibold"
                            android:textSize="@dimen/text_data_numeric"
                            android:textColor="@color/primary" />

                    </LinearLayout>

                    <!-- Progress Bar -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:progress="44"
                        app:trackColor="@color/surface_container_high"
                        app:indicatorColor="@color/primary_container"
                        app:trackCornerRadius="2dp"
                        android:layout_marginBottom="@dimen/spacing_sm" />
                    <TextView
                        android:id="@+id/tv_stage_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:fontFamily="@font/jetbrains_mono_medium"
                        android:alpha="1"
                        android:layout_marginBottom="10dp"
                        android:textColor="@color/on_surface_variant"
                        android:text="Uploading scan to server..." />
                    <!-- AI Inference Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leaving this page may interrupt processing."
                        android:fontFamily="@font/jetbrains_mono_medium"
                        android:textSize="10sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/secondary"
                        android:textAllCaps="false" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Step Progress Indicator ─── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.NeuroAge.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.gs.neuroage.BrainScanAnimationView
                    android:id="@+id/view_brain_animation"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ─── Bottom Navigation ─── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        style="@style/Widget.NeuroAge.BottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>